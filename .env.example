# ── Local Docker development ──────────────────────────────────────────────────
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/kitchen_manager?schema=public"
# DIRECT_URL="postgresql://postgres:postgres@localhost:5432/kitchen_manager?schema=public"
# (DIRECT_URL equals DATABASE_URL locally; they only differ on Neon)

# ── Neon (production) ─────────────────────────────────────────────────────────
# DATABASE_URL  = pooled connection string from Neon dashboard (Connection Details → Pooled)
# DIRECT_URL    = direct (non-pooled) connection string from Neon dashboard (Connection Details → Direct)
# DATABASE_URL="postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"
# DIRECT_URL="postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# ── Anthropic API ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
